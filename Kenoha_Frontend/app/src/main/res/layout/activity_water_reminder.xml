<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFC"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 Water Reminder"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- Enable Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:background="@android:color/white"
            android:elevation="3dp"
            android:layout_marginBottom="24dp"
            android:clipToOutline="true"
            android:layoutAnimation="@anim/layout_fade_in">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Reminder"
                android:textSize="18sp"
                android:textColor="#1E293B" />

            <Switch
                android:id="@+id/switchReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="38dp"
                android:minHeight="38dp"
                android:thumbTint="#2196F3"
                android:trackTint="#BBDEFB" />

        </LinearLayout>

        <!-- Input Section -->
        <LinearLayout
            android:id="@+id/inputSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:animateLayoutChanges="true">


            <!-- From Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="From:"
                    android:textSize="16sp"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/fromTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Time"
                    android:textColor="#2196F3"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- To Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="To:"
                    android:textSize="16sp"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/toTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Time"
                    android:textColor="#2196F3"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
            <!-- Time Interval Heading -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time Interval"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="10dp" />

            <!-- Repeat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/repeatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Repeat:"
                    android:textSize="16sp"
                    android:textColor="#374151"
                    android:layout_marginEnd="200dp" />

                <TextView
                    android:id="@+id/repeatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Everyday"
                    android:textColor="#2196F3"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Interval Options -->
            <RadioGroup
                android:id="@+id/intervalGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">



                <RadioButton
                    android:id="@+id/interval15"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Every 15 minutes" />

                <RadioButton
                    android:id="@+id/interval30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Every 30 minutes" />

                <RadioButton
                    android:id="@+id/interval60"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Every 1 hour" />

                <RadioButton
                    android:id="@+id/interval90"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Every 1.5 hours" />

                <RadioButton
                    android:id="@+id/interval120"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Every 2 hours" />
            </RadioGroup>

            <!-- Save Button -->
            <Button
                android:id="@+id/saveReminderButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" Save Reminder"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#2196F3"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                android:paddingVertical="10dp"
                android:layout_marginTop="10dp"
                android:stateListAnimator="@null"
                android:background="@drawable/rounded_button" />
        </LinearLayout>

        <!-- Saved Reminders -->
        <LinearLayout
            android:id="@+id/savedRemindersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="30dp"
            android:animateLayoutChanges="true" />
    </LinearLayout>
</ScrollView>
