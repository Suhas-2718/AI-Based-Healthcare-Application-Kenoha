<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:padding="20dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Greeting -->
        <TextView
            android:id="@+id/greetingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi User"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="25dp"
            android:alpha="0"
            android:translationY="20dp"
            android:animateLayoutChanges="true" />

        <!-- Grid for Dashboard Cards -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true">

            <androidx.cardview.widget.CardView
                android:id="@+id/userDetailsCard"
                style="@style/DashboardCard"
                app:cardBackgroundColor="#C8E6C9">

                <LinearLayout style="@style/CardInner">
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_ud"
                        android:contentDescription="User Details" />

                    <TextView
                        style="@style/CardTitle"
                        android:text="User Details" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/remindersCard"
                style="@style/DashboardCard"
                app:cardBackgroundColor="#FFF9C4">

                <LinearLayout style="@style/CardInner">
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_rem"
                        android:contentDescription="Reminders" />

                    <TextView
                        style="@style/CardTitle"
                        android:text="Reminders" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/quickAssistCard"
                style="@style/DashboardCard"
                app:cardBackgroundColor="#E8EAF6">

                <LinearLayout style="@style/CardInner">
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_qa"
                        android:contentDescription="Quick Assistance" />

                    <TextView
                        style="@style/CardTitle"
                        android:text="Quick Assistance" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:id="@+id/emergencyCard"
                style="@style/DashboardCard"
                app:cardBackgroundColor="#FFCDD2">

                <LinearLayout style="@style/CardInner">
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/ic_call"
                        android:contentDescription="Emergency Call" />

                    <TextView
                        style="@style/CardTitle"
                        android:text="Emergency Call" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </GridLayout>
    </LinearLayout>
</ScrollView>